{
  "id": "clawguard-monitor",
  "endpoints": {
    "analyze": "/analyze-thread"
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "backendUrl": {
        "type": "string",
        "description": "ClawGuard backend URL"
      },
      "apiKey": {
        "type": "string",
        "description": "Your ClawGuard API key (starts with cg_)"
      },
      "agentId": {
        "type": "string",
        "description": "Identifier for this agent",
        "default": "default"
      },
      "blockSensitiveAccess": {
        "type": "boolean",
        "description": "Block access to sensitive files (.env, credentials, SSH keys)",
        "default": false
      },
      "requireApprovalForHighRisk": {
        "type": "boolean",
        "description": "Require user approval before potential data exfiltration",
        "default": false
      }
    },
    "required": ["backendUrl", "apiKey"]
  }
}
