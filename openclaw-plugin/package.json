{
  "name": "clawguard-monitor",
  "version": "0.1.0",
  "description": "ClawGuard security monitoring plugin for OpenClaw agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --dir ../tests/openclaw-plugin",
    "test:watch": "vitest --dir ../tests/openclaw-plugin",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "security",
    "monitoring",
    "clawguard",
    "ai-agent",
    "telegram"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rutipo/clawguard-sdk.git",
    "directory": "openclaw-plugin"
  },
  "homepage": "https://github.com/rutipo/clawguard-sdk#readme",
  "author": "ClawGuard",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  }
}
